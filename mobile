<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <title>Football Canva Mobile v5</title>
  <style>
    :root {
      --bg: #0f1115;
      --panel: #171a21;
      --panel-2: #0f131b;
      --line: #252a36;
      --line-2: #31384a;
      --text: #ffffff;
      --muted: #a8b0c4;
      --accent: #ffd84d;
      --success: #1f9d64;
      --danger: #b83a3a;
      --radius: 18px;
    }
    * { box-sizing: border-box; }
    html, body { margin:0; padding:0; background:var(--bg); color:var(--text); font-family: Arial, sans-serif; -webkit-tap-highlight-color: transparent; }
    body { min-height:100vh; }
    .wrap { max-width: 1500px; margin: 0 auto; padding: 16px; padding-bottom: 92px; }
    .hero { text-align:center; margin-bottom:16px; }
    .hero h1 { margin:0 0 8px; font-size: clamp(24px, 4vw, 36px); }
    .hero p { margin:0; color:var(--muted); line-height:1.8; font-size:15px; }
    .layout { display:grid; grid-template-columns: minmax(330px, 460px) 1fr; gap:16px; align-items:start; }
    .card { background:var(--panel); border:1px solid var(--line); border-radius:var(--radius); padding:15px; box-shadow:0 14px 26px rgba(0,0,0,.22); margin-bottom:14px; }
    .card h2, .card h3 { margin:0 0 12px; font-size:18px; }
    .row { margin-bottom:12px; }
    .label { display:block; margin-bottom:8px; font-size:14px; font-weight:bold; color:#e1e7f4; }
    .muted, .status-line { color:var(--muted); font-size:13px; line-height:1.7; }
    input[type="file"], input[type="text"], input[type="number"], select, textarea {
      width:100%; padding:12px; border-radius:13px; border:1px solid var(--line-2); background:var(--panel-2); color:var(--text); outline:none; font-size:15px;
    }
    textarea { min-height: 88px; resize: vertical; line-height: 1.7; }
    input[type="range"] { width:100%; margin:0; accent-color:var(--accent); min-height:34px; }
    input[type="checkbox"] { width:18px; height:18px; accent-color:var(--accent); }
    button { width:100%; border:0; border-radius:13px; padding:13px 14px; font-size:15px; font-weight:bold; cursor:pointer; touch-action: manipulation; transition: transform .15s ease, opacity .15s ease; }
    button:active { transform:scale(.98); } button:disabled { opacity:.55; cursor:not-allowed; }
    .primary { background:var(--accent); color:#111; } .secondary { background:#283041; color:#fff; } .success { background:var(--success); color:#fff; } .danger { background:var(--danger); color:#fff; }
    .two, .three, .four, .btns { display:grid; gap:10px; }
    .two { grid-template-columns:1fr 1fr; } .three { grid-template-columns:repeat(3,1fr); } .four { grid-template-columns:repeat(4,1fr); } .btns { grid-template-columns:1fr 1fr; }
    .chip-row { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; }
    .chip { border:1px solid var(--line-2); background:var(--panel-2); border-radius:13px; padding:12px 10px; text-align:center; font-size:14px; font-weight:bold; cursor:pointer; user-select:none; }
    .chip.active { background:var(--accent); color:#111; border-color:var(--accent); }
    .palette-group { margin-top:12px; padding:12px; border:1px solid var(--line); border-radius:14px; background:rgba(255,255,255,.02); }
    .palette-title { margin:0 0 10px; font-size:13px; color:var(--muted); font-weight:bold; }
    .swatches { display:grid; grid-template-columns:repeat(6, 1fr); gap:10px; }
    .swatch { height:38px; border-radius:12px; border:2px solid rgba(255,255,255,.12); cursor:pointer; position:relative; box-shadow:inset 0 0 0 1px rgba(0,0,0,.18); }
    .swatch.active::after { content:"✓"; position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-weight:bold; color:#fff; text-shadow:0 1px 2px rgba(0,0,0,.55); font-size:16px; }
    .preset-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; }
    .preset-btn { width:100%; background:var(--panel-2); color:var(--text); border:1px solid var(--line-2); border-radius:14px; padding:12px; text-align:right; line-height:1.5; }
    .preset-btn small { display:block; color:var(--muted); font-size:12px; margin-top:4px; font-weight:normal; }
    .inline-check { display:flex; align-items:center; gap:8px; background:var(--panel-2); border:1px solid var(--line-2); padding:11px 12px; border-radius:13px; min-height:47px; }
    .preview-panel { display:flex; flex-direction:column; gap:14px; min-width:0; }
    .preview-meta { display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; }
    .canvas-shell { position:relative; background:#090c12; border:1px solid var(--line); border-radius:18px; overflow:auto; min-height:520px; display:flex; align-items:center; justify-content:center; padding:14px; }
    canvas { display:block; max-width:100%; height:auto; background:#000; border-radius:16px; box-shadow:0 16px 40px rgba(0,0,0,.35); touch-action:none; user-select:none; }
    .overlay-pill { position:absolute; right:14px; bottom:14px; background:rgba(15,19,27,.88); border:1px solid rgba(255,255,255,.08); border-radius:999px; padding:9px 12px; font-size:12px; color:#d9dfef; pointer-events:none; backdrop-filter:blur(8px); }
    .small-grid { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
    .nudge-grid { display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; max-width:250px; margin:0 auto; }
    .nudge-grid .empty { visibility:hidden; }
    .sticky-actions { position:fixed; right:10px; left:10px; bottom:10px; z-index:30; display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; background:rgba(15,17,21,.92); border:1px solid rgba(255,255,255,.08); border-radius:18px; padding:10px; backdrop-filter:blur(10px); box-shadow:0 18px 30px rgba(0,0,0,.28); }
    .sticky-actions button { padding:12px 10px; font-size:14px; }
    .layer-list { display:flex; flex-direction:column; gap:8px; }
    .layer-item { background:var(--panel-2); border:1px solid var(--line-2); border-radius:14px; padding:10px; display:grid; grid-template-columns:1fr auto; gap:8px; align-items:center; }
    .layer-item.active { border-color:var(--accent); box-shadow: inset 0 0 0 1px var(--accent); }
    .layer-item-title { font-weight:bold; font-size:14px; }
    .layer-item-sub { color:var(--muted); font-size:12px; margin-top:3px; }
    .layer-actions { display:flex; gap:6px; flex-wrap:wrap; }
    .mini-btn { width:auto; min-width:42px; padding:8px 10px; border-radius:10px; background:#273044; color:#fff; font-size:12px; }
    .mini-btn.warn { background:#7a6320; } .mini-btn.bad { background:#7b2d2d; }
    .section-note { padding:10px 12px; background:rgba(255,255,255,.03); border:1px solid var(--line); border-radius:12px; color:var(--muted); font-size:13px; line-height:1.7; }
    @media (max-width:1080px) { .layout { grid-template-columns:1fr; } .preview-panel { order:-1; } .canvas-shell { min-height:330px; } }
    @media (max-width:720px) { .wrap { padding:12px; } .card { padding:14px; border-radius:16px; } .two, .three, .four, .btns, .chip-row, .small-grid, .preset-grid { grid-template-columns:1fr; } button, input, select, textarea { font-size:16px; } .preview-meta { align-items:flex-start; flex-direction:column; } .layer-item { grid-template-columns:1fr; } }
  </style>

  <meta name="theme-color" content="#0f1115" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Football Canva" />
  <link rel="manifest" href="manifest.json" />
  <link rel="icon" href="icons/icon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="icons/icon.svg" />

</head>
<body>
  <div class="wrap">
    <div class="hero">
      <h1>⚽ Football Canva Mobile v5</h1>
      <p>نسخة أقوى للتيم: Multi Text Layers + Layer Order + Templates + Logo Library + Autosave، مع Drag / Pinch Zoom / Rotate للموبايل.</p>
    </div>

    <div class="layout">
      <div>
        <div class="card">
          <h2>1) مقاس التصميم</h2>
          <div class="chip-row" id="sizeChips">
            <div class="chip active" data-size="portrait">1080×1350</div>
            <div class="chip" data-size="square">1080×1080</div>
            <div class="chip" data-size="landscape">1920×1080</div>
            <div class="chip" data-size="reset">Reset</div>
          </div>
          <div class="status-line" style="margin-top:10px;" id="sizeStatus">المقاس الحالي: 1080 × 1350</div>
        </div>

        <div class="card">
          <h2>2) الملفات والمكتبات</h2>
          <div class="row">
            <label class="label">الصورة الأساسية</label>
            <input type="file" id="bgInput" accept="image/*" />
          </div>
          <div class="row two">
            <div>
              <label class="label">رفع لوجو جديد</label>
              <input type="file" id="logoInput" accept="image/*" />
            </div>
            <div>
              <label class="label">اسم اللوجو</label>
              <input type="text" id="logoName" placeholder="مثال: Premier League" />
            </div>
          </div>
          <div class="row btns">
            <button class="success" id="saveLogoBtn" type="button">حفظ اللوجو بالمكتبة</button>
            <button class="secondary" id="addLogoLayerBtn" type="button">إضافة لوجو Layer</button>
          </div>
          <div class="row two">
            <div>
              <label class="label">مكتبة اللوجوهات</label>
              <select id="savedLogosSelect"></select>
            </div>
            <div class="btns" style="margin-top:26px;">
              <button class="secondary" id="applySavedLogoBtn" type="button">استخدم اللوجو</button>
              <button class="danger" id="deleteSavedLogoBtn" type="button">حذف اللوجو</button>
            </div>
          </div>
          <hr style="border-color:var(--line); opacity:.35; margin:14px 0;" />
          <div class="row two">
            <div>
              <label class="label">رفع فريم جديد</label>
              <input type="file" id="frameInput" accept="image/*" />
            </div>
            <div>
              <label class="label">اسم الفريم</label>
              <input type="text" id="frameName" placeholder="مثال: Match Result Frame" />
            </div>
          </div>
          <div class="row btns">
            <button class="success" id="saveFrameBtn" type="button">حفظ الفريم</button>
            <button class="secondary" id="useFrameTempBtn" type="button">استخدامه الآن</button>
          </div>
          <div class="row two">
            <div>
              <label class="label">الفريمات المحفوظة للمقاس الحالي</label>
              <select id="savedFramesSelect"></select>
            </div>
            <div class="btns" style="margin-top:26px;">
              <button class="secondary" id="applySavedFrameBtn" type="button">تفعيل الفريم</button>
              <button class="danger" id="deleteSavedFrameBtn" type="button">حذف الفريم</button>
            </div>
          </div>
          <div class="muted">كل اللوجوهات والفريمات بتتحفظ داخل نفس المتصفح على نفس الجهاز ✅</div>
        </div>

        <div class="card">
          <h2>3) القوالب الجاهزة</h2>
          <div class="preset-grid" id="templateButtons">
            <button class="preset-btn" type="button" data-template="breaking">Breaking News<small>عنوان كبير + لوجو + فريم خبر</small></button>
            <button class="preset-btn" type="button" data-template="result">Match Result<small>نتيجة كبيرة + سطر سفلي</small></button>
            <button class="preset-btn" type="button" data-template="lineup">Lineup<small>عنوان + 3 سطور جاهزة</small></button>
            <button class="preset-btn" type="button" data-template="transfer">Transfer<small>عنوان انتقال + سطر توضيحي</small></button>
          </div>
          <div class="section-note" style="margin-top:12px;">القالب بيضيف Text Layers جاهزة سريعة. الفريم أو اللوجو لو موجودين في المكتبة تقدر تطبقهم بعد القالب مباشرة ✨</div>
        </div>

        <div class="card">
          <h2>4) الطبقات Layers</h2>
          <div class="row btns">
            <button class="primary" id="addTextLayerBtn" type="button">+ إضافة Text Layer</button>
            <button class="secondary" id="duplicateLayerBtn" type="button">تكرار Layer</button>
          </div>
          <div class="row btns">
            <button class="secondary" id="moveUpBtn" type="button">⬆️ للأمام</button>
            <button class="secondary" id="moveDownBtn" type="button">⬇️ للخلف</button>
          </div>
          <div class="layer-list" id="layerList"></div>
          <div class="muted" style="margin-top:10px;">آخر Layer في القائمة هي اللي فوق في التصميم. الفريم دائمًا فوق الجميع.</div>
        </div>

        <div class="card">
          <h2>5) خصائص الـ Layer النشطة</h2>
          <div class="row status-line" id="activeLayerText">Layer نشطة: الصورة</div>
          <div class="row" id="textEditorWrap">
            <label class="label">النص</label>
            <textarea id="textValue" placeholder="اكتب النص هنا"></textarea>
          </div>
          <div class="row four" id="textControlsWrap">
            <div>
              <label class="label">حجم الخط</label>
              <input type="number" id="fontSize" value="86" min="12" max="240" />
            </div>
            <div>
              <label class="label">الخط</label>
              <select id="fontFamily">
                <option value="Arial, sans-serif">Arial</option>
                <option value="Tahoma, sans-serif">Tahoma</option>
                <option value="Verdana, sans-serif">Verdana</option>
                <option value="Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif">Impact</option>
                <option value="Georgia, serif">Georgia</option>
                <option value="'Trebuchet MS', sans-serif">Trebuchet MS</option>
                <option value="'Arial Black', Gadget, sans-serif">Arial Black</option>
                <option value="system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif">System UI</option>
              </select>
            </div>
            <div>
              <label class="label">لون الخط</label>
              <input type="text" id="textColor" value="#ffffff" />
            </div>
            <div>
              <label class="label">لون الـ Stroke</label>
              <input type="text" id="strokeColor" value="#000000" />
            </div>
          </div>
          <div class="row two" id="textControlsWrap2">
            <div>
              <label class="label">سمك الـ Stroke</label>
              <input type="range" id="strokeWidth" min="0" max="20" step="1" value="6" />
            </div>
            <div>
              <label class="label">المحاذاة</label>
              <select id="textAlign">
                <option value="center">وسط</option>
                <option value="right">يمين</option>
                <option value="left">شمال</option>
              </select>
            </div>
          </div>
          <div class="palette-group" id="textPaletteWrap">
            <div class="palette-title">ألوان سريعة للنص</div>
            <div class="swatches" id="textPalette"></div>
            <div class="palette-title" style="margin-top:10px;">ألوان سريعة للـ Stroke</div>
            <div class="swatches" id="strokePalette"></div>
          </div>
          <div class="palette-group" id="textPresetWrap">
            <div class="palette-title">ستايلات نص سريعة</div>
            <div class="preset-grid" id="textPresets">
              <button class="preset-btn" type="button" data-preset="breaking">Breaking News<small>أبيض + Stroke قوي</small></button>
              <button class="preset-btn" type="button" data-preset="result">Match Result<small>أصفر واضح للأرقام</small></button>
              <button class="preset-btn" type="button" data-preset="lineup">Lineup<small>ستايل تشكيل أنيق</small></button>
              <button class="preset-btn" type="button" data-preset="transfer">Transfer<small>سماوي + حد داكن</small></button>
            </div>
          </div>
          <div class="row two" style="margin-top:12px;">
            <div class="inline-check"><input type="checkbox" id="layerVisible" checked /> <label for="layerVisible">إظهار Layer</label></div>
            <div class="inline-check"><input type="checkbox" id="layerLocked" /> <label for="layerLocked">Lock Layer</label></div>
          </div>
          <div class="row four">
            <div>
              <label class="label">X</label>
              <input type="number" id="layerX" />
            </div>
            <div>
              <label class="label">Y</label>
              <input type="number" id="layerY" />
            </div>
            <div>
              <label class="label">Scale</label>
              <input type="number" id="layerScale" step="0.01" min="0.05" max="10" />
            </div>
            <div>
              <label class="label">Rotate</label>
              <input type="number" id="layerRotate" step="1" min="-360" max="360" />
            </div>
          </div>
          <div class="row" id="bgFitWrap">
            <label class="label">طريقة عرض الصورة</label>
            <select id="bgFit">
              <option value="cover">Cover</option>
              <option value="contain">Contain</option>
            </select>
          </div>
          <div class="row btns">
            <button class="secondary" id="resetLayerBtn" type="button">Reset Layer</button>
            <button class="secondary" id="centerLayerBtn" type="button">Center Layer</button>
          </div>
          <div class="nudge-grid">
            <div class="empty"></div>
            <button class="mini-btn" id="nudgeUp" type="button">⬆️</button>
            <div class="empty"></div>
            <button class="mini-btn" id="nudgeLeft" type="button">⬅️</button>
            <button class="mini-btn warn" id="deleteLayerBtn" type="button">🗑</button>
            <button class="mini-btn" id="nudgeRight" type="button">➡️</button>
            <div class="empty"></div>
            <button class="mini-btn" id="nudgeDown" type="button">⬇️</button>
            <div class="empty"></div>
          </div>
        </div>
      </div>

      <div class="preview-panel">
        <div class="card">
          <div class="preview-meta">
            <div>
              <h2 style="margin:0 0 6px;">المعاينة المباشرة</h2>
              <div class="muted" id="statusText">جاهز للشغل ✨</div>
              <div class="muted" id="projectText">Autosave: شغال</div>
            </div>
            <div class="inline-check"><input type="checkbox" id="showGuides" checked /> <label for="showGuides">Show Guides</label></div>
          </div>
          <div class="canvas-shell">
            <canvas id="canvas" width="1080" height="1350"></canvas>
            <div class="overlay-pill" id="gesturePill">Drag • Pinch Zoom • Rotate</div>
          </div>
          <div class="row btns" style="margin-top:12px;">
            <button class="primary" id="renderBtn" type="button">تحديث</button>
            <button class="secondary" id="previewCleanBtn" type="button">Preview Clean Export</button>
          </div>
          <div class="row btns">
            <button class="success" id="downloadPngBtn" type="button">تحميل PNG</button>
            <button class="success" id="downloadJpgBtn" type="button">تحميل JPG</button>
          </div>
          <div class="row btns">
            <button class="secondary" id="toggleGuidesBtn" type="button">Show / Hide Guides</button>
            <button class="secondary" id="saveProjectBtn" type="button">حفظ يدوي الآن</button>
          </div>
          <div class="row two">
            <div class="inline-check"><input type="checkbox" id="highQuality" checked /> <label for="highQuality">جودة أعلى</label></div>
            <button class="danger" id="resetProjectBtn" type="button">Reset Project</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="sticky-actions">
    <button class="secondary" id="stickyRenderBtn" type="button">تحديث</button>
    <button class="success" id="stickyPngBtn" type="button">PNG</button>
    <button class="primary" id="stickySaveBtn" type="button">Save</button>
  </div>

  <script>
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    const sizeChips = Array.from(document.querySelectorAll('#sizeChips .chip'));
    const sizeStatus = document.getElementById('sizeStatus');
    const statusText = document.getElementById('statusText');
    const projectText = document.getElementById('projectText');
    const gesturePill = document.getElementById('gesturePill');
    const showGuidesInput = document.getElementById('showGuides');
    const highQualityInput = document.getElementById('highQuality');
    const activeLayerText = document.getElementById('activeLayerText');
    const layerList = document.getElementById('layerList');

    const bgInput = document.getElementById('bgInput');
    const logoInput = document.getElementById('logoInput');
    const logoNameInput = document.getElementById('logoName');
    const savedLogosSelect = document.getElementById('savedLogosSelect');
    const frameInput = document.getElementById('frameInput');
    const frameNameInput = document.getElementById('frameName');
    const savedFramesSelect = document.getElementById('savedFramesSelect');

    const textValueInput = document.getElementById('textValue');
    const fontSizeInput = document.getElementById('fontSize');
    const fontFamilyInput = document.getElementById('fontFamily');
    const textColorInput = document.getElementById('textColor');
    const strokeColorInput = document.getElementById('strokeColor');
    const strokeWidthInput = document.getElementById('strokeWidth');
    const textAlignInput = document.getElementById('textAlign');
    const layerVisibleInput = document.getElementById('layerVisible');
    const layerLockedInput = document.getElementById('layerLocked');
    const layerXInput = document.getElementById('layerX');
    const layerYInput = document.getElementById('layerY');
    const layerScaleInput = document.getElementById('layerScale');
    const layerRotateInput = document.getElementById('layerRotate');
    const bgFitInput = document.getElementById('bgFit');

    const textEditorWrap = document.getElementById('textEditorWrap');
    const textControlsWrap = document.getElementById('textControlsWrap');
    const textControlsWrap2 = document.getElementById('textControlsWrap2');
    const textPaletteWrap = document.getElementById('textPaletteWrap');
    const textPresetWrap = document.getElementById('textPresetWrap');
    const bgFitWrap = document.getElementById('bgFitWrap');

    const sizes = {
      portrait: { width: 1080, height: 1350, label: '1080 × 1350' },
      square: { width: 1080, height: 1080, label: '1080 × 1080' },
      landscape: { width: 1920, height: 1080, label: '1920 × 1080' }
    };

    const storage = {
      frames: 'football.v5.frames',
      logos: 'football.v5.logos',
      project: 'football.v5.project',
      lastFrame: 'football.v5.lastFrame'
    };

    const palettes = ['#ffffff','#000000','#ffd84d','#ff3b30','#00c2ff','#00d084','#f97316','#a855f7','#ef4444','#1d4ed8','#94a3b8','#111827'];
