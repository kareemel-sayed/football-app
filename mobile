      app.savedFrames[app.sizeKey] = (app.savedFrames[app.sizeKey] || []).filter(item => item.id !== frameId); persistFrames(); populateSavedFramesSelect(); if (app.frame.frameId === frameId) { app.frame.image = null; app.frame.frameId = ''; render(); } queueAutosave();
