        const t1 = createTextLayer('تم التعاقد رسميًا'); Object.assign(t1, textPresets.transfer, { y: Math.round(size.height * 0.16), fontSize: 98 });
        const t2 = createTextLayer('اسم اللاعب'); Object.assign(t2, textPresets.breaking, { y: Math.round(size.height * 0.74), fontSize: 84 });
