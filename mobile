    function persistLogos() { localStorage.setItem(storage.logos, JSON.stringify(app.savedLogos)); }
    function loadLogos() { try { app.savedLogos = JSON.parse(localStorage.getItem(storage.logos) || '[]') || []; } catch { app.savedLogos = []; } }
