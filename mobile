      const list = app.savedFrames[app.sizeKey] || []; list.unshift(item); app.savedFrames[app.sizeKey] = list.slice(0, 20); persistFrames(); populateSavedFramesSelect(); savedFramesSelect.value = item.id; await applyFrameById(item.id); statusText.textContent = 'تم حفظ الفريم ✅';
