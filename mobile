    function serializeProject() {
      return {
        sizeKey: app.sizeKey,
        activeLayerId: app.activeLayerId,
        projectSavedAt: new Date().toLocaleString('ar-EG'),
        background: { ...cloneData(app.background), image: app.background.image ? imageToDataURL(app.background.image) : '' },
        textLayers: app.textLayers.map(layer => cloneData(layer)),
        logoLayers: app.logoLayers.map(layer => ({ ...cloneData(layer), image: layer.image ? imageToDataURL(layer.image) : '' })),
        frame: { ...cloneData(app.frame), image: app.frame.image ? imageToDataURL(app.frame.image) : '' },
        savedFrames: app.savedFrames,
        savedLogos: app.savedLogos
      };
    }

    function queueAutosave() {
      clearTimeout(app.autosaveTimer);
      app.autosaveTimer = setTimeout(() => saveProject(true), 450);
    }

    async function saveProject(silent = false) {
      const project = serializeProject();
      localStorage.setItem(storage.project, JSON.stringify(project));
      app.projectSavedAt = project.projectSavedAt; projectText.textContent = `Autosave: آخر حفظ ${app.projectSavedAt}`;
      if (!silent) statusText.textContent = 'تم حفظ المشروع ✅';
    }

    async function loadProject() {
      try {
        const raw = localStorage.getItem(storage.project); if (!raw) return;
        const project = JSON.parse(raw);
        if (project.sizeKey && sizes[project.sizeKey]) app.sizeKey = project.sizeKey;
        app.savedFrames = project.savedFrames || app.savedFrames; app.savedLogos = project.savedLogos || app.savedLogos;
        app.background = { ...app.background, ...project.background, image: await dataURLToImage(project.background?.image || '') };
        app.textLayers = (project.textLayers || []).map(item => ({ ...createTextLayer(''), ...item }));
        app.logoLayers = [];
        for (const item of (project.logoLayers || [])) { app.logoLayers.push({ ...createLogoLayer(null), ...item, image: await dataURLToImage(item.image || '') }); }
        app.frame = { ...app.frame, ...project.frame, image: await dataURLToImage(project.frame?.image || '') };
        app.activeLayerId = project.activeLayerId || app.background.id;
        app.projectSavedAt = project.projectSavedAt || null;
      } catch (error) { console.error(error); }
      updateCanvasSize();
      sizeChips.forEach(chip => chip.classList.toggle('active', chip.dataset.size === app.sizeKey));
      populateSavedFramesSelect(); populateSavedLogosSelect(); syncEditorsFromLayer(); render();
