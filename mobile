    function applyTemplate(name) {
      app.textLayers = [];
      const size = getCanvasSize();
      if (name === 'breaking') {
        const t1 = createTextLayer('عاجل'); Object.assign(t1, textPresets.breaking, { y: Math.round(size.height * 0.14), fontSize: 110 });
        const t2 = createTextLayer('اكتب عنوان الخبر هنا'); Object.assign(t2, textPresets.breaking, { y: Math.round(size.height * 0.78), fontSize: 82 });
