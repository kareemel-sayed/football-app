      app.frame.image = await dataURLToImage(item.dataUrl); app.frame.frameId = item.id; localStorage.setItem(storage.lastFrame, JSON.stringify({ ...JSON.parse(localStorage.getItem(storage.lastFrame) || '{}'), [app.sizeKey]: item.id })); renderAndMaybeSave('تم تفعيل الفريم ✅');
    }
    function applyLastSavedFrameForCurrentSize() {
      try { const map = JSON.parse(localStorage.getItem(storage.lastFrame) || '{}'); if (map[app.sizeKey]) applyFrameById(map[app.sizeKey]); } catch {}
    }
    async function saveFrameToLibrary() {
      if (!app.tempFrameImage) return alert('ارفع الفريم الأول.');
